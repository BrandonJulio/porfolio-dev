---
// Particles.astro
---
<canvas id="particle-canvas"></canvas>

<style>
  #particle-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1; /* Se mantiene al fondo */
    pointer-events: none; /* Permite hacer click a los elementos de arriba */
    background: transparent; /* Sin fondo, se adapta a tu layout */
  }
</style>

<script>
  class ParticleNetwork {
    canvas: HTMLCanvasElement;
    ctx: CanvasRenderingContext2D;
    particles: Array<{ x: number; y: number; vx: number; vy: number; radius: number }>;
    numParticles: number;
    connectionDistance: number;
    mouse: { x: number | null; y: number | null };

    constructor() {
      this.canvas = document.getElementById('particle-canvas') as HTMLCanvasElement;
      this.ctx = this.canvas.getContext('2d')!;
      this.particles = [];
      
      // Ajustes de densidad y distancia
      this.numParticles = Math.floor((window.innerWidth * window.innerHeight) / 9000);
      this.connectionDistance = 120;
      
      this.mouse = { x: null, y: null };

      this.init();
    }

    init() {
      this.resizeCanvas();
      this.createParticles();
      
      // Eventos
      window.addEventListener('resize', () => this.resizeCanvas());
      window.addEventListener('mousemove', (e) => {
        this.mouse.x = e.clientX;
        this.mouse.y = e.clientY;
      });
      window.addEventListener('mouseleave', () => {
        this.mouse.x = null;
        this.mouse.y = null;
      });

      // Iniciar animación
      this.animate();
    }

    resizeCanvas() {
      this.canvas.width = window.innerWidth;
      this.canvas.height = window.innerHeight;
      // Recalcular número de partículas si la pantalla cambia drásticamente
      this.numParticles = Math.floor((this.canvas.width * this.canvas.height) / 9000);
    }

    createParticles() {
      this.particles = [];
      for (let i = 0; i < this.numParticles; i++) {
        this.particles.push({
          x: Math.random() * this.canvas.width,
          y: Math.random() * this.canvas.height,
          vx: (Math.random() - 0.5) * 0.5, // Velocidad suave
          vy: (Math.random() - 0.5) * 0.5,
          radius: Math.random() * 2 + 1.5 // Tamaño de los nodos (puntos blancos)
        });
      }
    }

    animate() {
      this.ctx.clearRect(0, 0, this.canvas.width, this.canvas.height);

      // Dibujar y actualizar partículas
      this.particles.forEach((p) => {
        p.x += p.vx;
        p.y += p.vy;

        // Rebotar en los bordes
        if (p.x < 0 || p.x > this.canvas.width) p.vx *= -1;
        if (p.y < 0 || p.y > this.canvas.height) p.vy *= -1;

        // Dibujar el nodo (punto blanco translúcido)
        this.ctx.beginPath();
        this.ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
        this.ctx.fillStyle = 'rgba(255, 255, 255, 0.7)';
        this.ctx.fill();
      });

      // Dibujar las líneas de conexión
      for (let i = 0; i < this.particles.length; i++) {
        for (let j = i + 1; j < this.particles.length; j++) {
          const p1 = this.particles[i];
          const p2 = this.particles[j];

          const dx = p1.x - p2.x;
          const dy = p1.y - p2.y;
          const dist = Math.sqrt(dx * dx + dy * dy);

          if (dist < this.connectionDistance) {
            // La opacidad de la línea depende de la cercanía
            const alpha = (1 - dist / this.connectionDistance) * 0.25;
            this.ctx.beginPath();
            this.ctx.moveTo(p1.x, p1.y);
            this.ctx.lineTo(p2.x, p2.y);
            this.ctx.strokeStyle = `rgba(255, 255, 255, ${alpha})`;
            this.ctx.lineWidth = 0.8;
            this.ctx.stroke();
          }
        }

        // Conexión opcional con el mouse
        if (this.mouse.x !== null && this.mouse.y !== null) {
          const p1 = this.particles[i];
          const dx = p1.x - this.mouse.x;
          const dy = p1.y - this.mouse.y;
          const dist = Math.sqrt(dx * dx + dy * dy);

          if (dist < this.connectionDistance * 1.5) {
            const alpha = (1 - dist / (this.connectionDistance * 1.5)) * 0.3;
            this.ctx.beginPath();
            this.ctx.moveTo(p1.x, p1.y);
            this.ctx.lineTo(this.mouse.x, this.mouse.y);
            this.ctx.strokeStyle = `rgba(255, 255, 255, ${alpha})`;
            this.ctx.lineWidth = 1;
            this.ctx.stroke();
          }
        }
      }

      requestAnimationFrame(() => this.animate());
    }
  }

  // Ejecutar cuando el script se cargue en el cliente
  new ParticleNetwork();
</script>